{
  "entry": [
    "app/app.vue",
    "app/pages/**/*.vue",
    "app/components/**/*.vue",
    "app/composables/**/*.ts",
    "app/stores/**/*.ts",
    "server/**/*.ts",
    "scripts/sync-commanders.ts"
  ],
  "ignorePatterns": [
    "public/**",
    "docs/**",
    "shared/utils/types/database.ts",
    "i18n/i18n.config.ts"
  ],
  "ignoreDependencies": [
    "@formkit/auto-animate",
    "@iconify-json/lucide",
    "@iconify-json/simple-icons",
    "@nuxt/hints",
    "@vue/test-utils",
    "@vueuse/core",
    "playwright-core"
  ],
  "duplicates": {
    "mode": "weak",
    "ignore": [
      "public/**",
      "docs/**",
      "shared/utils/types/database.ts",
      "i18n/i18n.config.ts"
    ]
  },
  "rules": {
    "unused-store-members": "off"
  }
}
